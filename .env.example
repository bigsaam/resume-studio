# Copy to `.env` and fill in. Never commit `.env`.

# --- Server -----------------------------------------------------------------
PORT=3000
# Public origin. Must match the Google OAuth redirect URI's scheme/host/port.
ORIGIN=http://localhost:3000

# --- Storage ----------------------------------------------------------------
# DATA_ROOT holds the SQLite DB, the session signing secret, per-resume PDFs,
# and user asset uploads. It must NEVER live inside a Typst compile root.
DATA_ROOT=./data
DATABASE_PATH=./data/resume-studio.db

# Seed directory: `seed/<email>.json` pre-populates that user's first resume.
SEED_DIR=./seed

# --- Auth -------------------------------------------------------------------
# Google OAuth (OIDC). Create credentials at https://console.cloud.google.com
# Authorized redirect URI must be exactly: ${ORIGIN}/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Comma-separated emails allowed to sign in without an invite code.
# The FIRST user to sign in becomes an admin (can mint invite codes).
ALLOWED_EMAILS=you@example.com

# Session cookie signing secret. If unset, a random one is generated and
# persisted to $DATA_ROOT/auth-secret (mode 0600).
#   openssl rand -hex 32
AUTH_SECRET=

# Force the `Secure` cookie flag. Defaults to true when ORIGIN is https.
# AUTH_COOKIE_SECURE=true

# --- Rendering --------------------------------------------------------------
TYPST_BIN=typst
# Directory of .ttf/.otf files passed to `typst --font-path`. Read-only.
FONT_PATH=./fonts
# Hard wall-clock cap on a single typst compile (ms).
TYPST_TIMEOUT_MS=20000
# Max concurrent typst processes across the whole instance.
TYPST_CONCURRENCY=2

# --- Agent ------------------------------------------------------------------
# The chat editor runs on the operator's Anthropic account — it pays for ALL
# users' usage. Keep the limits below tight.
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-5
CLAUDE_MAX_TURNS=12
# Per-user daily cap on agent chat turns.
CHAT_TURNS_PER_DAY=100
