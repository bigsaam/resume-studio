# Copy to `.env` and fill in. Never commit `.env`.

# --- Server -----------------------------------------------------------------
PORT=3000
# Public origin. Must match the Google OAuth redirect URI's scheme/host/port.
ORIGIN=http://localhost:3000

# --- Storage ----------------------------------------------------------------
# DATA_ROOT holds the SQLite DB, the session signing secret, per-resume PDFs,
# and user asset uploads. It must NEVER live inside a Typst compile root.
DATA_ROOT=./data
DATABASE_PATH=./data/resume-studio.db

# Seed directory: `seed/<email>.json` pre-populates that user's first resume.
SEED_DIR=./seed

# --- Auth -------------------------------------------------------------------
# Google OAuth (OIDC). Create credentials at https://console.cloud.google.com
# Authorized redirect URI must be exactly: ${ORIGIN}/auth/google/callback
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Comma-separated emails allowed to sign in without an invite code.
# The FIRST user to sign in becomes an admin (can mint invite codes).
ALLOWED_EMAILS=you@example.com

# Session cookie signing secret. If unset, a random one is generated and
# persisted to $DATA_ROOT/auth-secret (mode 0600).
#   openssl rand -hex 32
AUTH_SECRET=

# Force the `Secure` cookie flag. Defaults to true when ORIGIN is https.
# AUTH_COOKIE_SECURE=true

# --- Uploads ----------------------------------------------------------------
# Every uploaded image is fully decoded and re-encoded, which is what discards
# EXIF/GPS and defuses polyglot files. SVG is refused outright.
MAX_UPLOAD_BYTES=8388608
# Decode ceiling: a small file can declare a huge canvas ("decompression bomb").
MAX_IMAGE_PIXELS=40000000
# Longest edge of the stored image; anything bigger is scaled down.
MAX_IMAGE_DIM=2000
# Per-user ceilings, so one account can't fill the disk. A count alone is a weak
# bound: 50 images of incompressible noise are tens of megabytes each.
MAX_ASSETS_PER_USER=50
MAX_BYTES_PER_USER=67108864
# Concurrent image decodes. Each can hold MAX_IMAGE_PIXELS x 4 bytes of raw
# pixels, so this — not the request rate — is what bounds upload memory.
UPLOAD_CONCURRENCY=2

# --- Rendering --------------------------------------------------------------
TYPST_BIN=typst
# Directory of .ttf/.otf files passed to `typst --font-path`. Read-only.
FONT_PATH=./fonts
# Hard wall-clock cap on a single typst compile (ms).
TYPST_TIMEOUT_MS=20000
# Max concurrent typst processes across the whole instance.
TYPST_CONCURRENCY=2

# --- Agent ------------------------------------------------------------------
# The chat editor runs on the operator's Anthropic account — it pays for ALL
# users' usage. Keep the limits below tight.
# Leave ANTHROPIC_API_KEY empty to disable chat entirely: the Chat tab shows a
# notice and POST /api/resumes/:id/chat returns 503.
ANTHROPIC_API_KEY=
# Alternative to the API key, if you authenticate with a Claude subscription.
# CLAUDE_CODE_OAUTH_TOKEN=
CLAUDE_MODEL=claude-sonnet-5
# Tool-use steps the agent may take within one turn (get/edit/render each count).
CLAUDE_MAX_TURNS=12
# Per-user daily cap on agent chat turns. Reserved before the model is called,
# and refunded only if nothing was billed.
CHAT_TURNS_PER_DAY=100
# The real bound on spend. A turn count says nothing about cost: one twelve-step
# turn over a long résumé costs far more than a dozen one-step turns. Checked
# before a turn starts, so a turn may overshoot by its own size — never by more.
CHAT_TOKENS_PER_DAY=400000
# Burst control, so one user can't monopolise the Typst semaphore.
CHAT_TURNS_PER_MINUTE=6
# Invite-code guesses per client address per hour. Codes are 128-bit and hashed,
# and each guess costs a full Google round-trip, but nothing else bounds them.
INVITE_ATTEMPTS_PER_HOUR=10
# Hard wall-clock cap on one chat turn (ms).
CHAT_TIMEOUT_MS=120000
# Reject a longer chat message before it reaches the model.
MAX_CHAT_MESSAGE_CHARS=4000
